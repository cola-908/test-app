def extract_from_clients(src_dir):
    """从API客户端源码动态提取"""
    cases = []
    cid = [0]
    module_map = {
        'win_api.py': ('PC/Server', '/v2/proxy/CentralizedBackup'),
        'file_api.py': ('FileServer', '/v2/proxy2/CentralizedBackup'),
        'vmware_api.py': ('VMware', '/v2/proxy2/CentralizedBackup'),
        'hyperv_api.py': ('Hyper-V', '/v2/proxy2/CentralizedBackup/58200'),
        'tos_api.py': ('TOS\u7cfb\u7edf', ''),
    }
    for fname, (mod, prefix) in module_map.items():
        fp = os.path.join(src_dir, fname)
        if not os.path.isfile(fp):
            continue
        with open(fp) as f:
            src = f.read()
        for m in re.finditer(r'def (\w+)\(self.*?\):\s*(?:"""(.*?)""")?', src, re.DOTALL):
            mname, doc = m.group(1), (m.group(2) or '').strip()
            if mname.startswith('_'):
                continue
            hm = re.search(r'self\.client\.(get|post|put|delete)\(\s*[fr]?["\']([^"\']+)', src[m.start():m.start()+600])
            if not hm:
                continue
            meth, path = hm.group(1).upper(), hm.group(2)
            cid[0] += 1
            cases.append({
                'id': f'CB-{cid[0]:03d}', 'module': mod,
                'path': prefix + path if prefix else path,
                'method': meth, 'priority': 'P2',
                'feature': '\u5176\u4ed6', 'title': mname,
                'preconditions': '\u5df2\u767b\u5f55TOS',
                'steps': f'1. {meth} {path}',
                'expected': '\u8fd4\u56de200\uff0c\u8bf7\u6c42\u6210\u529f',
                'remark': '', 'status': 'pending', 'latency': 0, 'response': None,
            })
    return cases

def run_single(test, base_url, headers=None, cookies=None):
    """执行单个接口测试"""
    # 路径处理
    path = re.sub(r'\{[^}]+\}', '0', test['path'])
    # # 5050 内部 API：需要去掉 /v2 前缀
    # # 8181 nginx：保持完整 /v2/proxy/... 路径
    # if base_url.startswith('http://127.0.0.1:5050'):
    #     path = re.sub(r'^/v2', '', path)
    # 追加 query_params
    qp = test.get('query_params', '')
    if qp:
        path = path + '?' + qp
    url = base_url + path
    method = test['method'].lower()
    t0 = time.time()
    try:
        if not HAS_REQUESTS:
            return {'status': 'failed', 'duration_ms': 0, 'response_code': 0, 'response_body': json.dumps({'error': 'requests library not installed'}, ensure_ascii=False), 'response': {'error': 'requests library not installed'}}

        # 策略1: 优先使用后端已认证的 session
        use_auth_session = auth_state.get('logged_in') and get_auth_session()
        if use_auth_session:
            sess = get_auth_session()
            csrf = auth_state.get('csrf_token', '')
            req_headers = {'X-Csrf-Token': csrf} if csrf else {}
            if headers:
                req_headers.update(headers)
            kw = dict(headers=req_headers, timeout=15)
            if method in ('post', 'put', 'delete'):
                kw['json'] = test.get('body') or {}
            r = getattr(sess, method)(url, **kw)
        else:
            # 策略2: fallback 使用前端传来的 cookies/csrf
            if not cookies and not headers:
                return {'status': 'failed', 'duration_ms': 0, 'response_code': 0,
                        'response_body': json.dumps({'error': 'please login', 'code_num': 117}, ensure_ascii=False),
                        'response': {'error': 'No authenticated session and no browser cookies provided'}}
            req_headers = dict(headers or {})
            req_cookies = dict(cookies or {})
            kw = dict(headers=req_headers, cookies=req_cookies, timeout=15, verify=False)
            if method in ('post', 'put', 'delete'):
                kw['json'] = test.get('body') or {}
            sess = req_lib.Session()
            sess.verify = False
            r = getattr(sess, method)(url, **kw)

        elapsed = time.time() - t0
        try:
            body = r.json()
        except Exception:
            body = {'_status': r.status_code, '_text': r.text[:MAX_RESPONSE_BODY]}
        # 检查是否 session 已过期 (please login)
        if body.get('code_num') == 117 or body.get('code_msg', '') == 'please login':
            auth_state['logged_in'] = False
        # 截断大body
        body_str = json.dumps(body, ensure_ascii=False, default=str)
        if len(body_str) > MAX_RESPONSE_BODY * 2:
            body = {'_truncated': True, '_status': r.status_code}
        ok = r.status_code == 200 and body.get('code', True) is True
        return {
            'status': 'passed' if ok else 'failed',
            'duration_ms': round(elapsed * 1000),
            'response_code': r.status_code,
            'response_body': json.dumps(body, ensure_ascii=False, default=str),
            'method': method.upper(),
            'url': url,
            'response': {'status_code': r.status_code, 'body': body},
        }
    except Exception as e:
        return {'status': 'failed', 'duration_ms': 0, 'response_code': 0, 'response_body': json.dumps({'error': str(e)}, ensure_ascii=False), 'response': {'error': str(e)}}

# ─── HTTP Handler ────────────────────────────────────
class Handler(http.server.BaseHTTPRequestHandler):
    def do_GET(self):
        path = urllib.parse.urlparse(self.path).path
        for p in [f'/{APP_ID}', f'/{APP_ID}/']:
            if path.startswith(p):
                path = path[len(p):] or '/'
                break
        if path.startswith('/api/'):
            self._api('GET', path, None)
        else:
            self._static(path)

    def do_PUT(self):
        path = urllib.parse.urlparse(self.path).path
        for p in [f'/{APP_ID}', f'/{APP_ID}/']:
            if path.startswith(p):
                path = path[len(p):] or '/'
                break
        cl = int(self.headers.get('Content-Length', 0))
        raw = self.rfile.read(cl) if cl > 0 else b''
        try:
            data = json.loads(raw) if raw else {}
        except Exception:
            data = {}
        self._api('PUT', path, data)

    def do_DELETE(self):
        path = urllib.parse.urlparse(self.path).path
        for p in [f'/{APP_ID}', f'/{APP_ID}/']:
            if path.startswith(p):
                path = path[len(p):] or '/'
                break
        cl = int(self.headers.get('Content-Length', 0))
        raw = self.rfile.read(cl) if cl > 0 else b''
        try:
            data = json.loads(raw) if raw else {}
        except Exception:
            data = {}
        self._api('DELETE', path, data)

    def do_POST(self):
        path = urllib.parse.urlparse(self.path).path
        for p in [f'/{APP_ID}', f'/{APP_ID}/']:
            if path.startswith(p):
                path = path[len(p):] or '/'
                break
        cl = int(self.headers.get('Content-Length', 0))
        raw = self.rfile.read(cl) if cl > 0 else b''
        try:
            data = json.loads(raw) if raw else {}
        except Exception:
            data = {}
        self._api('POST', path, data)

    def do_OPTIONS(self):
        self.send_response(200)
        self.send_header('Access-Control-Allow-Origin', '*')
        self.send_header('Access-Control-Allow-Methods', 'POST, GET, OPTIONS')
        self.send_header('Access-Control-Allow-Headers', 'Content-Type, X-Csrf-Token, Cookie')
        self.send_header('Access-Control-Max-Age', '86400')
        self.end_headers()

    def _static(self, path):
        if path in ('/', ''):
            path = '/index.html'
        fp = os.path.join(WEBUI_DIR, path.lstrip('/'))
        rw = os.path.realpath(WEBUI_DIR)
        rf = os.path.realpath(fp)
        if not rf.startswith(rw):
            self.send_error(403)
            return
        if os.path.isfile(rf):
            ext = rf.rsplit('.', 1)[-1].lower()
            with open(rf, 'rb') as f:
                data = f.read()
            self.send_response(200)
            self.send_header('Content-Type', CONTENT_TYPES.get(ext, 'application/octet-stream'))
            self.send_header('Content-Length', str(len(data)))
            self.send_header('Cache-Control', 'no-store')
            self.end_headers()
            self.wfile.write(data)
        else:
            self.send_error(404)

    def _api(self, method, path, data):
        if path == '/api/tests':
            self._json({'code': True, 'data': test_cases})
        elif path == '/api/run' and method == 'POST':
            self._run(data or {})
        elif path == '/api/progress':
            d = dict(run_state)
            d['done'] = d.get('completed', 0)
            self._json({'code': True, 'data': d})
        elif path == '/api/results':
            self._json({'code': True, 'data': {'results': run_state.get('results', {})}})
        elif path == '/api/stop':
            run_state['stop'] = True
            self._json({'code': True, 'data': {'stopping': True}})
        elif path == '/api/health':
            self._json({'code': True, 'data': {'status': 'ok', 'app': APP_ID, 'tests': len(test_cases), 'auth': auth_state['logged_in']}})
        elif path == '/api/login' and method == 'POST':
            self._handle_login(data or {})
        elif path == '/api/auth_status':
            logged = auth_state['logged_in']
            uname = auth_state['username']
            b_url = auth_state['base_url']
            # 如果未登录但请求带了 TOS cookie，自动信任
            if not logged:
                ck = {}
                ch = self.headers.get('Cookie', '')
                for p in ch.split(';'):
                    p = p.strip()
                    if '=' in p:
                        k, v = p.split('=', 1)
                        ck[k.strip()] = v.strip()
                if ck.get('TMSESSNAME') and ck.get('X-Csrf-Token'):
                    auth_state['session'] = None
                    auth_state['cookies'] = {'TMSESSNAME': ck['TMSESSNAME'], 'X-Csrf-Token': ck['X-Csrf-Token']}
                    auth_state['csrf_token'] = ck['X-Csrf-Token']
                    auth_state['logged_in'] = True
                    if b_url == 'http://127.0.0.1:5050':
                        auth_state['base_url'] = 'http://127.0.0.1:8181'
                    b_url = auth_state['base_url']
                    logged = True
                    uname = 'demo'
