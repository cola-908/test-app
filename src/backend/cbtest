    def _handle_login(self, data):
        """处理前端登录请求"""
        username = data.get('username', '')
        password = data.get('password', '')
        base_url = data.get('base_url', auth_state['base_url'])
        browser_session = data.get('browser_session', '')
        browser_csrf = data.get('browser_csrf', '')
        if base_url:
            auth_state['base_url'] = base_url

        # 策略1: 优先用浏览器 session（直接信任，不验证）
        if browser_session and browser_csrf and HAS_REQUESTS:
            auth_state['session'] = None
            auth_state['cookies'] = {'TMSESSNAME': browser_session, 'X-Csrf-Token': browser_csrf}
            auth_state['csrf_token'] = browser_csrf
            auth_state['logged_in'] = True
            auth_state['username'] = username or 'demo'
            if password:
                auth_state['password'] = password
            log.info(f"Browser session login OK, user={auth_state['username']}")
            self._json({'code': True, 'data': {'logged_in': True, 'username': auth_state['username']}})
            return

        # 策略2: 有用户名+密码，RSA 加密登录
        if username and password:
            ok, msg = login_tos(username=username, password=password)
            if ok:
                self._json({'code': True, 'data': {'logged_in': True, 'username': username}})
            else:
                self._json({'code': False, 'msg': msg})
            return

        # 策略3: 后端已登录
        if auth_state.get('logged_in'):
            self._json({'code': True, 'data': {'logged_in': True, 'username': auth_state.get('username', '')}})
            return

        self._json({'code': False, 'msg': '请输入用户名和密码进行登录'})

    def _case_update(self, data):
        """保存用例编辑"""
        cid = data.get('id', '')
        if not cid:
            self._json({'code': False, 'msg': 'missing id'})
            return
        case = next((c for c in test_cases if c.get('id') == cid), None)
        if not case:
            self._json({'code': False, 'msg': 'case not found'})
            return
        # 可编辑字段
        editable = ['path', 'method', 'title', 'body', 'path_params', 'query_params',
                    'priority', 'feature', 'preconditions', 'steps', 'expected']
        updates = {}
        for k in editable:
            if k in data:
                updates[k] = data[k]
                case[k] = data[k]
        if updates:
            _case_edits[cid] = updates
            _save_case_edits()
            _save_tests_json()
        self._json({'code': True, 'data': case})

    def _case_reset(self, data):
        """重置用例到原始状态"""
        cid = data.get('id', '')
        if not cid:
            self._json({'code': False, 'msg': 'missing id'})
            return
        # 从原始 JSON 重新加载该用例
        json_path = os.path.join(INSTALL_DIR, 'test_cases.json')
        if os.path.isfile(json_path):
            with open(json_path) as f:
                original = json.load(f)
            orig_case = next((c for c in original if c.get('id') == cid), None)
            if orig_case:
                # 更新 test_cases 中的对应项
                for i, c in enumerate(test_cases):
                    if c.get('id') == cid:
                        test_cases[i] = dict(orig_case)
                        break
                # 移除编辑
                _case_edits.pop(cid, None)
                _save_case_edits()
                _save_tests_json()
                self._json({'code': True, 'data': test_cases[i] if any(c.get('id') == cid for c in test_cases) else orig_case})
                return
        self._json({'code': False, 'msg': 'original not found'})

    def _sync_source(self, data):
        """将安装目录的 test_cases.json 同步回源码目录"""
        src_path = data.get('source_path', '/Volume1/eee/cb-test-app/src/test_cases.json')
        install_json = os.path.join(INSTALL_DIR, 'test_cases.json')
        if not os.path.isfile(install_json):
            self._json({'code': False, 'msg': 'install test_cases.json not found'})
            return
        try:
            os.makedirs(os.path.dirname(src_path), exist_ok=True)
            import shutil
            shutil.copy2(install_json, src_path)
            log.info(f"Synced test_cases.json to source: {src_path}")
            self._json({'code': True, 'data': {'synced_to': src_path, 'count': len(test_cases)}})
        except Exception as e:
            self._json({'code': False, 'msg': str(e)})

    def _case_add(self, data):
        """新增测试用例"""
        # 生成自增ID
        max_num = 0
        for c in test_cases:
            m = re.match(r'CB-(\d+)', c.get('id', ''))
            if m:
                max_num = max(max_num, int(m.group(1)))
        new_id = f'CB-{max_num + 1:03d}'

        new_case = {
            'id': new_id,
            'module': data.get('module', 'PC/Server'),
            'path': data.get('path', '/v2/proxy/CentralizedBackup/'),
            'method': data.get('method', 'GET'),
            'priority': data.get('priority', 'P2'),
            'feature': data.get('feature', ''),
            'title': data.get('title', f'新用例-{new_id}'),
            'preconditions': data.get('preconditions', '已登录TOS'),
            'steps': data.get('steps', ''),
            'expected': data.get('expected', '返回200，code=true'),
            'remark': data.get('remark', 'user-added'),
        }
        if data.get('path_params'):
            new_case['path_params'] = data['path_params']
        if data.get('query_params'):
            if isinstance(data['query_params'], dict):
                qp = data['query_params']
                new_case['query_params'] = '&'.join(f'{k}={v}' for k, v in qp.items()) if qp else ''
            else:
                new_case['query_params'] = str(data['query_params'])
        if data.get('body'):
            new_case['body'] = data['body']
        if data.get('body_schema'):
            new_case['body_schema'] = data['body_schema']

        test_cases.append(new_case)
        # 持久化到 case_edits
        _case_edits[new_id] = {'_action': 'add', **new_case}
        _save_case_edits()
        # 同步写入 test_cases.json
        _save_tests_json()
        log.info(f"Added new case {new_id}: {new_case['title']}")
        self._json({'code': True, 'data': new_case})

    def _case_delete(self, data):
        """删除用例"""
        cid = data.get('id', '')
        if not cid:
            self._json({'code': False, 'msg': 'missing id'})
            return
        idx = next((i for i, c in enumerate(test_cases) if c.get('id') == cid), -1)
        if idx < 0:
            self._json({'code': False, 'msg': 'case not found'})
            return
        test_cases.pop(idx)
        _case_edits.pop(cid, None)
        _save_case_edits()
        _save_tests_json()
        run_state['results'].pop(cid, None)
        log.info(f"Deleted case {cid}")
        self._json({'code': True, 'data': {'deleted': cid}})

