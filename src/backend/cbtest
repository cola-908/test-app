def _rsa_encrypt_pure(rsa_b64: str, plaintext: str) -> str:
    """纯 Python RSA PKCS1v15 加密（OpenSSL 3.x 兼容）"""
    import base64 as b64mod
    pem_text = b64mod.b64decode(rsa_b64).decode('utf-8')

    import subprocess
    pem_file = f'/tmp/cbtest_rsa_{os.getpid()}.pem'
    with open(pem_file, 'w') as f:
        f.write(pem_text)

    try:
        # 优先用 openssl pkeyutl (OpenSSL 3.x 兼容)
        result = subprocess.run(
            ['openssl', 'pkeyutl', '-encrypt', '-pubin', '-inkey', pem_file, '-pkeyopt', 'rsa_padding_mode:pkcs1'],
            input=plaintext.encode('utf-8'),
            capture_output=True, timeout=5
        )
        if result.returncode == 0:
            return b64mod.b64encode(result.stdout).decode('utf-8')
        # Fallback: 旧版 openssl rsautl
        result2 = subprocess.run(
            ['openssl', 'rsautl', '-encrypt', '-pubin', '-inkey', pem_file, '-pkcs'],
            input=plaintext.encode('utf-8'),
            capture_output=True, timeout=5
        )
        if result2.returncode == 0:
            return b64mod.b64encode(result2.stdout).decode('utf-8')
        raise RuntimeError(result.stderr.decode() or result2.stderr.decode())
    finally:
        try:
            os.unlink(pem_file)
        except OSError:
            pass

