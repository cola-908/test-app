def login_tos(username=None, password=None):
    """登录 TOS 获取 Cookie 和 CSRF Token"""
    if not HAS_REQUESTS:
        return False, 'requests library not installed'
    global auth_state
    if username:
        auth_state['username'] = username
    if password:
        auth_state['password'] = password

    base = auth_state['base_url']
    try:
        # 创建持久 session
        sess = req_lib.Session()
        sess.verify = False

        # Step 1: 获取 CSRF token + RSA 公钥
        login_path = '/login/state' if base.startswith('http://127.0.0.1:5050') else '/v2/login/state'
        r0 = sess.get(f"{base}{login_path}", timeout=10)
        csrf_token = r0.cookies.get('X-Csrf-Token', '')
        rsa_b64 = r0.headers.get('X-Rsa-Token', '')
        if not csrf_token:
            auth_state['logged_in'] = False
            return False, 'Failed to get CSRF token'

        # Step 2: 用 RSA 公钥加密密码
        encrypted_pwd = auth_state['password']
        if rsa_b64:
            try:
                encrypted_pwd = _rsa_encrypt_pure(rsa_b64, auth_state['password'])
            except Exception as e:
                log.warning(f"RSA encryption failed ({e}), trying plaintext login")

        # Step 3: 登录
        login_endpoint = '/login' if base.startswith('http://127.0.0.1:5050') else '/v2/login'
        r = sess.post(
            f"{base}{login_endpoint}",
            json={'username': auth_state['username'], 'password': encrypted_pwd},
            headers={'X-Csrf-Token': csrf_token},
            timeout=10
        )
        body = r.json()
        if not body.get('code', False):
            msg = body.get('msg', body.get('code_msg', 'unknown'))
            auth_state['logged_in'] = False
            return False, f'Login failed: {msg}'

        # Step 4: 刷新请求获取新 CSRF
        sess.get(f"{base}{login_path}", timeout=10)

        # 保存整个 session
        auth_state['session'] = sess
        auth_state['csrf_token'] = sess.cookies.get('X-Csrf-Token', csrf_token)
        auth_state['logged_in'] = True
        log.info(f"Logged in as {auth_state['username']}, CSRF={auth_state['csrf_token'][:8]}...")
        return True, 'ok'
    except Exception as e:
        auth_state['logged_in'] = False
        return False, str(e)


def get_auth_session():
    """获取带认证的 requests.Session"""
    sess = auth_state.get('session')
    if sess and auth_state['logged_in']:
        return sess
    # fallback: 创建带旧 cookies 的 session
    sess = req_lib.Session()
    sess.verify = False
    if auth_state.get('cookies'):
        for k, v in auth_state['cookies'].items():
            sess.cookies.set(k, v)
    return sess

