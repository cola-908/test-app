    def _scenario_record(self, sid, data):
        """录制模式：执行场景但不做断言，将响应存为 expected.snapshot"""
        if scenario_run_state['running']:
            self._json({'code': False, 'msg': '场景已在执行中'})
            return
        scenario = next((s for s in scenarios if s['id'] == sid), None)
        if not scenario:
            self._json({'code': False, 'msg': 'scenario not found'})
            return

        env = data.get('env', {})
        base_url = 'http://127.0.0.1:8181'
        req_cookie_header = self.headers.get('Cookie', '')
        browser_session = env.get('session', '')
        browser_csrf = env.get('csrf_token', '')
        if not browser_session or not browser_csrf:
            for pair in req_cookie_header.split(';'):
                pair = pair.strip()
                if '=' in pair:
                    k, v = pair.split('=', 1)
                    k = k.strip(); v = v.strip()
                    if k == 'X-Csrf-Token' and not browser_csrf:
                        browser_csrf = v
                    if k == 'TMSESSNAME' and not browser_session:
                        browser_session = v

        if not browser_session or not browser_csrf:
            self._json({'code': False, 'msg': '未检测到登录信息'})
            return

        headers = {'X-Csrf-Token': browser_csrf}
        cookies = {'TMSESSNAME': browser_session, 'X-Csrf-Token': browser_csrf}

        steps = scenario.get('steps', [])
        steps.sort(key=lambda x: x.get('order', 0))

        scenario_run_state['running'] = True
        scenario_run_state['stop'] = False
        scenario_run_state['steps'] = []
        ctx = {}

        def recorder():
            for i, step in enumerate(steps):
                if scenario_run_state['stop']:
                    scenario_run_state['steps'].append({'order': step.get('order'), 'title': step.get('title',''), 'status': 'skipped'})
                    continue
                test_case = next((t for t in test_cases if t['id'] == step['case_id']), None)
                if not test_case:
                    scenario_run_state['steps'].append({'order': step.get('order'), 'title': step.get('title',''), 'status': 'error', 'error': 'case not found'})
                    break
                test_run = dict(test_case)
                overrides = step.get('overrides', {})
                if overrides:
                    resolved = _resolve_vars(overrides, ctx)
                    if resolved.get('path_params'):
                        pp = test_run.get('path_params', {})
                        pp.update(resolved['path_params'])
                        test_run['path_params'] = pp
                    if resolved.get('body') is not None:
                        test_run['body'] = resolved['body']
                pp = test_run.get('path_params', {})
                if pp:
                    for k, v in pp.items():
                        pp[k] = _resolve_vars(v, ctx)
                    resolved_path = test_run['path']
                    for k, v in pp.items():
                        resolved_path = resolved_path.replace('{' + k + '}', str(v))
                    test_run['path'] = resolved_path
                api_url = base_url.replace('127.0.0.1:5050', '127.0.0.1:8181')
                result = run_single(test_run, api_url, headers, cookies)
                # 录制：从结果中提取 expected
                resp_body = result.get('response', {}).get('body', '')
                expected = {
                    'status_code': result.get('response_code', 200),
                    'snapshot': {'body': resp_body, 'mode': 'exact'}
                }
                # 更新 step 的 expected
                step['expected'] = expected
                # 也提取变量（供后续步骤用）
                extracted = _extract_vars(result, step.get('extract', {}))
                ctx.update(extracted)
                scenario_run_state['steps'].append({
                    'order': step.get('order'),
                    'title': step.get('title', ''),
                    'status': 'recorded',
                    'response_code': result.get('response_code', 0),
                    'extracted': extracted
                })
            _save_scenarios()
            scenario_run_state['running'] = False
            # 保存录制记录
            run_steps = scenario_run_state.get('steps', [])
            run_data = {
                'id': f"rec_{int(time.time()*1000)}",
                'scenario_id': sid,
                'scenario_name': scenario.get('name', ''),
                'started_at': datetime.now().strftime('%Y-%m-%dT%H:%M:%S'),
                'finished_at': datetime.now().strftime('%Y-%m-%dT%H:%M:%S'),
                'status': 'recorded',
                'total': len(run_steps),
                'passed': len(run_steps),
                'failed': 0,
                'steps': run_steps
            }
            _add_scenario_run(run_data)

        threading.Thread(target=recorder, daemon=True).start()
        self._json({'code': True, 'data': {'started': True, 'total': len(steps), 'id': sid}})

    def _scenario_run(self, sid, data):
        if scenario_run_state['running']:
            self._json({'code': False, 'msg': '场景已在执行中'})
            return
        scenario = next((s for s in scenarios if s['id'] == sid), None)
        if not scenario:
            self._json({'code': False, 'msg': 'scenario not found'})
            return

        env = data.get('env', {})
        base_url = 'http://127.0.0.1:8181'  # 固定走 8181 nginx

        # 从请求 Cookie 头提取 browser session
        req_cookie_header = self.headers.get('Cookie', '')
        browser_session = env.get('session', '')
        browser_csrf = env.get('csrf_token', '')
        if not browser_session or not browser_csrf:
            for pair in req_cookie_header.split(';'):
                pair = pair.strip()
                if '=' in pair:
                    k, v = pair.split('=', 1)
                    k = k.strip(); v = v.strip()
                    if k == 'X-Csrf-Token' and not browser_csrf:
                        browser_csrf = v
                    if k == 'TMSESSNAME' and not browser_session:
                        browser_session = v

        if not browser_session or not browser_csrf:
            self._json({'code': False, 'msg': '未检测到登录信息，请先登录 TOS'})
            return

        log.info(f"Scenario run with browser session, session={browser_session[:8]}...")

        # 构建请求用的 headers/cookies
        headers = {'X-Csrf-Token': browser_csrf}
        cookies = {'TMSESSNAME': browser_session, 'X-Csrf-Token': browser_csrf}
        auth_state['logged_in'] = False  # 强制 run_single 走策略2

        steps = scenario.get('steps', [])
        steps.sort(key=lambda x: x.get('order', 0))

        scenario_run_state['running'] = True
        scenario_run_state['stop'] = False
        scenario_run_state['current_step'] = 0
        scenario_run_state['steps'] = []
        scenario_run_state['ctx'] = {}

        def worker():
            ctx = {}
            for i, step in enumerate(steps):
                if scenario_run_state['stop']:
                    scenario_run_state['steps'].append({'order': step.get('order'), 'case_id': step.get('case_id'), 'title': step.get('title',''), 'status': 'skipped'})
                    continue
                scenario_run_state['current_step'] = i + 1
                # 找对应用例
                test_case = next((t for t in test_cases if t['id'] == step['case_id']), None)
                if not test_case:
                    scenario_run_state['steps'].append({'order': step.get('order'), 'case_id': step.get('case_id'), 'title': step.get('title',''), 'status': 'error', 'error': 'case not found'})
                    break
                # 合并覆盖参数并替换变量
                test_run = dict(test_case)
                overrides = step.get('overrides', {})
                if overrides:
                    resolved = _resolve_vars(overrides, ctx)
                    if resolved.get('path_params'):
                        pp = test_run.get('path_params', {})
                        pp.update(resolved['path_params'])
                        test_run['path_params'] = pp
                    if resolved.get('body') is not None:
                        test_run['body'] = resolved['body']
                # 解析路径参数（先对值做变量替换）
                pp = test_run.get('path_params', {})
                if pp:
                    # 用 ctx 变量替换路径参数值
                    for k, v in pp.items():
                        pp[k] = _resolve_vars(v, ctx)
                    resolved_path = test_run['path']
                    for k, v in pp.items():
                        resolved_path = resolved_path.replace('{' + k + '}', str(v))
                    test_run['path'] = resolved_path
                # 执行（API 请求走 8181 nginx 入口，绕过 session 验证）
                api_url = base_url.replace('127.0.0.1:5050', '127.0.0.1:8181')
                result = run_single(test_run, api_url, headers, cookies)
                # 提取变量
                extracted = _extract_vars(result, step.get('extract', {}))
                ctx.update(extracted)
                scenario_run_state['ctx'] = dict(ctx)
                scenario_run_state['steps'].append({
                    'order': step.get('order'),
                    'case_id': step.get('case_id'),
                    'title': step.get('title', ''),
                    'status': result['status'],
                    'duration_ms': result.get('duration_ms', 0),
                    'response_code': result.get('response_code', 0),
                    'extracted': extracted,
                    'response_body': result.get('response_body', '')[:500]
                })
                if result['status'] != 'passed':
                    break
                time.sleep(0.1)
            scenario_run_state['running'] = False
            # 保存执行记录
            run_steps = scenario_run_state.get('steps', [])
            total = len(run_steps)
            passed = sum(1 for s in run_steps if s.get('status') == 'passed')
            failed = sum(1 for s in run_steps if s.get('status') == 'failed')
            run_status = 'passed' if failed == 0 else ('failed' if passed == 0 else 'partial')
            run_data = {
                'id': f"run_{int(time.time()*1000)}",
                'scenario_id': sid,
                'scenario_name': scenario.get('name', ''),
                'started_at': datetime.now().strftime('%Y-%m-%dT%H:%M:%S'),
                'finished_at': datetime.now().strftime('%Y-%m-%dT%H:%M:%S'),
                'status': run_status,
                'total': total,
                'passed': passed,
                'failed': failed,
                'steps': run_steps
            }
            _add_scenario_run(run_data)

        threading.Thread(target=worker, daemon=True).start()
        self._json({'code': True, 'data': {'started': True, 'total': len(steps), 'id': sid}})

    def _run(self, data):
        if run_state['running']:
            self._json({'code': False, 'msg': '\u5df2\u5728\u6267\u884c\u4e2d'})
            return

        env = data.get('env', {})
        base_url = 'http://127.0.0.1:8181'
        ids = data.get('ids', [])
        module = data.get('module', 'all')
        case_overrides = data.get('case_overrides', {})

        # \u4ece\u8bf7\u6c42 Cookie \u5934\u63d0\u53d6 browser session
        browser_session = env.get('session', '')
        browser_csrf = env.get('csrf_token', '')
        if not browser_session or not browser_csrf:
            req_cookie_header = self.headers.get('Cookie', '')
            for pair in req_cookie_header.split(';'):
                pair = pair.strip()
                if '=' in pair:
                    k, v = pair.split('=', 1)
                    k = k.strip(); v = v.strip()
                    if k == 'X-Csrf-Token' and not browser_csrf:
                        browser_csrf = v
                    if k == 'TMSESSNAME' and not browser_session:
                        browser_session = v

        if not browser_session or not browser_csrf:
            self._json({'code': False, 'msg': '\u672a\u68c0\u6d4b\u5230\u767b\u5f55\u4fe1\u606f\uff0c\u8bf7\u5148\u767b\u5f55 TOS'})
            return

        headers = {'X-Csrf-Token': browser_csrf}
        cookies = {'TMSESSNAME': browser_session, 'X-Csrf-Token': browser_csrf}
        auth_state['logged_in'] = False

        targets = [t for t in test_cases if t['id'] in ids] if ids else list(test_cases)
        if module != 'all':
            ml = {'win': 'PC/Server', 'file': 'FileServer', 'vmware': 'VMware', 'hyperv': 'Hyper-V', 'tos': 'TOS'}
            mo = ml.get(module, module)
            targets = [t for t in targets if t['module'] == mo]

        run_state['running'] = True
        run_state['stop'] = False
        run_state['completed'] = 0
        run_state['total'] = len(targets)
        run_state['results'] = {}

        def worker():
            for t in targets:
                if run_state['stop']:
                    t['status'] = 'skipped'
                    run_state['results'][t['id']] = {'status': 'skipped', 'duration_ms': 0, 'response_code': 0, 'response_body': '', 'response': None}
                    run_state['completed'] += 1
                    continue
                tid = t['id']
                overrides = case_overrides.get(tid, {})
                test_run = dict(t)
                if overrides.get('path_params'):
                    test_run['path_params'] = overrides['path_params']
                if overrides.get('body') is not None:
                    test_run['body'] = overrides['body']
                pp = test_run.get('path_params', {})
                if pp:
                    resolved_path = test_run['path']
                    for k, v in pp.items():
                        resolved_path = resolved_path.replace('{' + k + '}', str(v))
                    test_run['path'] = resolved_path
                t['status'] = 'running'
                result = run_single(test_run, base_url, headers, cookies)
                t['status'] = result['status']
                t['latency'] = result.get('duration_ms', 0)
                t['response'] = result.get('response', None)
                run_state['results'][t['id']] = result
                run_state['completed'] += 1
                time.sleep(0.05)
            run_state['running'] = False

        threading.Thread(target=worker, daemon=True).start()
        self._json({'code': True, 'data': {'started': True, 'total': len(targets)}})

    def _json(self, data, code=200):
        body = json.dumps(data, ensure_ascii=False, default=str).encode('utf-8')
        self.send_response(code)
        self.send_header('Content-Type', 'application/json; charset=utf-8')
        self.send_header('Content-Length', str(len(body)))
        self.send_header('Access-Control-Allow-Origin', '*')
        self.end_headers()
        self.wfile.write(body)

    def log_message(self, fmt, *args):
        pass

class UnixSocketHTTPServer(http.server.HTTPServer):
    address_family = socket.AF_UNIX

def extract_webui():
    bz2_path = os.path.join(INSTALL_DIR, 'webui.bz2')
    if os.path.isfile(bz2_path):
        os.makedirs(WEBUI_DIR, exist_ok=True)
        with bz2.open(bz2_path, 'rb') as f:
            with tarfile.open(fileobj=f, mode='r') as tar:
                tar.extractall(WEBUI_DIR)
        log.info("Extracted webui.bz2")

def main():
    extract_webui()
    load_tests()
    _load_scenarios()
    # 自动尝试登录本地 TOS
    if HAS_REQUESTS:
        ok, msg = login_tos()
        if ok:
            log.info("Auto-login succeeded")
        else:
            log.warning(f"Auto-login failed: {msg}")
    os.makedirs(os.path.dirname(SOCKET_PATH), exist_ok=True)
    if os.path.exists(SOCKET_PATH):
        os.unlink(SOCKET_PATH)
    server = UnixSocketHTTPServer(SOCKET_PATH, Handler)
    os.chmod(SOCKET_PATH, 0o666)
    def shutdown(sig, frame):
        server.server_close()
        if os.path.exists(SOCKET_PATH):
            os.unlink(SOCKET_PATH)
        sys.exit(0)
    signal.signal(signal.SIGTERM, shutdown)
    signal.signal(signal.SIGINT, shutdown)
    log.info(f"CB Test listening on {SOCKET_PATH}, {len(test_cases)} cases ready")
    try:
        server.serve_forever()
    except KeyboardInterrupt:
        shutdown(None, None)

if __name__ == '__main__':
    main()
