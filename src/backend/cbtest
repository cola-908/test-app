def _resolve_vars(obj, ctx):
    """递归替换 {{var}} 占位符"""
    if isinstance(obj, str):
        for k, v in ctx.items():
            obj = obj.replace('{{' + k + '}}', str(v))
        return obj
    elif isinstance(obj, dict):
        return {k: _resolve_vars(v, ctx) for k, v in obj.items()}
    elif isinstance(obj, list):
        return [_resolve_vars(v, ctx) for v in obj]
    return obj

def _jsonpath_get(obj, path):
    """简单 JSONPath 取值: $.data.id 或 $.data.0.name"""
    if not path or not path.startswith('$'):
        return None
    parts = path.lstrip('$').strip('.').split('.')
    cur = obj
    for p in parts:
        if p == '':
            continue
        if isinstance(cur, dict):
            cur = cur.get(p)
        elif isinstance(cur, list):
            try:
                cur = cur[int(p)]
            except (IndexError, ValueError):
                return None
        else:
            return None
        if cur is None:
            return None
    return cur

def _extract_vars(result, extract_rules):
    """从响应中按规则提取变量"""
    extracted = {}
    if not extract_rules or not isinstance(extract_rules, dict):
        return extracted
    body = result.get('response', {}).get('body', {}) if result.get('response') else {}
    for var_name, jsonpath in extract_rules.items():
        val = _jsonpath_get(body, jsonpath)
        if val is not None:
            extracted[var_name] = val
            log.info(f"Extracted {var_name}={val} via {jsonpath}")
    return extracted
